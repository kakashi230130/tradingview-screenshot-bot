# TradingView cookies (copy từ Chrome DevTools → Application → Cookies)
TV_SESSIONID=
# Optional nhưng khuyến nghị điền để đăng nhập ổn định:
TV_SESSIONID_SIGN=

# Chart
SYMBOL=BINANCE:ETHUSDT.P
# Nếu bạn muốn dùng link chart cụ thể (có thể bỏ trống). Ví dụ:
# CHART_URL=https://www.tradingview.com/chart/dR50p2Km/
CHART_URL=

# Output
OUTPUT_DIR=output

# Browser
HEADLESS=true
SLOW_MO_MS=0
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# Lần đầu set 1 để bot mở UI và chờ bạn chỉnh indicator/save layout
MANUAL_SETUP=false

# Best-effort indicator automation (khuyến nghị false nếu chart đã có sẵn indicator)
ADD_INDICATORS=false
